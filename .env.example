RETRIEVAL_DATA_DIR=/data
QDRANT_URL=http://qdrant:6333
EMBEDDING_API_URL=http://embedding-api:8100
EMBEDDING_API_CONTRACT_VERSION=embedding-api.v1
EMBEDDING_TIMEOUT_SECONDS=30

DEFAULT_EMBEDDING_MODEL=BAAI/bge-m3
DEFAULT_EMBEDDING_NORMALIZE=true
DEFAULT_EMBEDDING_DISTANCE=Cosine
VALIDATE_EMBEDDING_CONTRACT_ON_STARTUP=false
VALIDATE_EMBEDDING_CONTRACT_ON_COLLECTION_CREATE=true
VALIDATE_EMBEDDING_CONTRACT_ON_SEARCH=true
ALLOW_MULTI_MODEL_SEARCH=false

RERANK_ENABLED=false
RRF_K=60
MAX_TOP_K=50
MAX_CANDIDATE_K=200
